{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dex2",
  "version": "0.1.0",
  "identifier": "cn.ygopro3.dex2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "dex2",
        "width": 1280,
        "height": 720
      }
    ],
    "security": {
      "csp": {
        "img-src": "'self' asset: http: https: blob: data:",
        "script-src": "'self' 'wasm-unsafe-eval'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "config.toml"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
